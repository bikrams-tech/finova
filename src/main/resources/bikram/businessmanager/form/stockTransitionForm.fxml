<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="mainVbox" alignment="TOP_CENTER" prefHeight="400.0" prefWidth="600.0" spacing="10.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="bikram.businessmanager.controller.inventory.InventoryTransitionFormController">
   <children>
      <HBox alignment="TOP_CENTER" prefHeight="46.0" prefWidth="570.0">
         <children>
            <Label fx:id="titleLabel" alignment="TOP_CENTER" prefHeight="46.0" prefWidth="170.0" HBox.hgrow="ALWAYS">
               <font>
                  <Font size="20.0" />
               </font>
               <HBox.margin>
                  <Insets />
               </HBox.margin>
            </Label>
            <Label prefHeight="52.0" prefWidth="79.0" text="Date:" textAlignment="CENTER" HBox.hgrow="ALWAYS">
               <padding>
                  <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
               </padding>
               <HBox.margin>
                  <Insets left="30.0" />
               </HBox.margin></Label>
            <Label fx:id="dateLabel" prefHeight="49.0" prefWidth="109.0" HBox.hgrow="ALWAYS" />
         </children>
      </HBox>
      <VBox prefHeight="200.0" prefWidth="100.0" spacing="10.0" VBox.vgrow="ALWAYS">
         <children>
            <VBox fx:id="hboxField" prefHeight="200.0" prefWidth="100.0" spacing="10.0" VBox.vgrow="ALWAYS">
               <children>
                  <Label fx:id="transitionLabel" prefHeight="33.0" prefWidth="168.0" />
                  <Label text="Quintity of product">
                     <font>
                        <Font size="15.0" />
                     </font>
                  </Label>
                  <TextField fx:id="qtyField" prefHeight="30.0" prefWidth="400.0" promptText="Quintity" />
               </children>
               <padding>
                  <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
               </padding>
            </VBox>
            <Button fx:id="saveBtn" mnemonicParsing="false" onAction="#onSaveClick" prefHeight="32.0" prefWidth="95.0" text="Save" />
         </children>
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </padding>
      </VBox>
   </children>
   <padding>
      <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
   </padding>
</VBox>
