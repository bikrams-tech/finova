<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox id="table-view" alignment="TOP_CENTER" prefHeight="400.0" prefWidth="600.0" stylesheets="@../../css/table-style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="bikram.businessmanager.controller.acounting.JournalEntryLineViewController">
   <children>
      <HBox prefHeight="100.0" prefWidth="200.0">
         <children>
            <Button mnemonicParsing="false" onAction="#on_back" text="←" />
         </children>
      </HBox>
      <Label alignment="TOP_CENTER" style="-fx-alignment: center;" text="Journal Entryes" underline="true" VBox.vgrow="ALWAYS">
         <font>
            <Font size="15.0" />
         </font>
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </padding>
      </Label>
      <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="accountColumn" prefWidth="150.0" text="Account" />
          <TableColumn fx:id="descriptioncolumn" prefWidth="200.0" text="Description" />
            <TableColumn fx:id="debitcolumn" prefWidth="150.0" text="Debit" />
            <TableColumn fx:id="creditColumn" prefWidth="150.0" text="Credit" />
        </columns>
      </TableView>
      <HBox prefHeight="43.0" prefWidth="600.0">
         <children>
            <Label prefHeight="47.0" prefWidth="93.0" text="Total Debit:">
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </Label>
            <Label fx:id="totalDebitLabel" prefHeight="43.0" prefWidth="106.0">
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </Label>
            <Label prefHeight="43.0" prefWidth="97.0" text="Total Credit:">
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </Label>
            <Label fx:id="totlCreditLabel" prefHeight="42.0" prefWidth="121.0">
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </Label>
         </children>
      </HBox>
   </children>
</VBox>
