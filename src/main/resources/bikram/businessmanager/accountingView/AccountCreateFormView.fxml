<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>

<BorderPane prefHeight="350" prefWidth="500" stylesheets="@../css/form/account_create_form.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="bikram.businessmanager.controller.acounting.AccountCreateFormController">
   <center>
        <GridPane hgap="15" styleClass="grid_pane" vgap="15" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <Label text="Account Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="accountNameField" promptText="Enter account name" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label text="Account Type:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <ComboBox fx:id="accountTypeSelectCombo" promptText="Select type" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label text="Company:" GridPane.rowIndex="2" />
            <ComboBox fx:id="companySelectComboBox" promptText="Select company" GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <Button onAction="#saveAccount" styleClass="primary-button" text="Save" GridPane.columnIndex="1" GridPane.rowIndex="4" />
         <Label prefHeight="23.0" prefWidth="39.0" text="Code:" GridPane.rowIndex="3" />
         <TextField fx:id="codeField" promptText="Account Code:" GridPane.columnIndex="1" GridPane.rowIndex="3" />
         <columnConstraints>
            <ColumnConstraints />
            <ColumnConstraints />
         </columnConstraints>
         <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
         </rowConstraints>

        </GridPane>
   </center>
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="50" spacing="10" styleClass="top-bar" BorderPane.alignment="CENTER">
            <children>

                <Button fx:id="backButton" mnemonicParsing="false" onAction="#on_back" styleClass="back-button" text="←" />

                <Label styleClass="title-label" text="Create Account" />

            </children>

            <padding>
                <Insets bottom="10" left="15" right="15" top="10" />
            </padding>
        </HBox>
    </top>

</BorderPane>
