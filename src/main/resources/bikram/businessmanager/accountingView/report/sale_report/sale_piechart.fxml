<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" prefWidth="1200.0" prefHeight="900.0"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="bikram.businessmanager.controller.inventory.report.sale_report.SalePieChartController">

    <children>

        <GridPane hgap="10" vgap="10" VBox.vgrow="ALWAYS">

            <columnConstraints>
                <ColumnConstraints percentWidth="50"/>
                <ColumnConstraints percentWidth="50"/>
            </columnConstraints>

            <rowConstraints>
                <RowConstraints percentHeight="33"/>
                <RowConstraints percentHeight="33"/>
                <RowConstraints percentHeight="34"/>
            </rowConstraints>

            <children>

                <BarChart fx:id="barchart_by_time" title="Sales by Time">
                    <xAxis>
                        <CategoryAxis />
                    </xAxis>
                    <yAxis>
                        <NumberAxis />
                    </yAxis>
                </BarChart>

                <LineChart fx:id="barchart_by_day" title="Sales by Day"
                          GridPane.columnIndex="1">
                    <xAxis>
                        <CategoryAxis />
                    </xAxis>
                    <yAxis>
                        <NumberAxis />
                    </yAxis>
                </LineChart>

                <LineChart fx:id="barchart_by_month" title="Sales by Month"
                          GridPane.rowIndex="1">
                    <xAxis>
                        <CategoryAxis />
                    </xAxis>
                    <yAxis>
                        <NumberAxis />
                    </yAxis>
                </LineChart>

                <PieChart fx:id="piechart_by_productCategory"
                          title="Sales by Product Category"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="1"/>

                <BarChart fx:id="top_product_bar_chart"
                          title="Top Selling Products"
                          GridPane.rowIndex="2">
                    <xAxis>
                        <CategoryAxis />
                    </xAxis>
                    <yAxis>
                        <NumberAxis />
                    </yAxis>
                </BarChart>

                <PieChart fx:id="piechart_by_paymentMethod"
                          title="Sales by Payment Method"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="2"/>

            </children>

        </GridPane>

    </children>
</VBox>