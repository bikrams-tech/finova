<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" style="-fx-background-color: linear-gradient(to bottom right, #6a00f4, #9d4edd);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="bikram.businessmanager.controller.company.CompanySelectViewController">

    <children>
      <VBox fx:id="onCreateNew" alignment="CENTER" prefHeight="484.0" prefWidth="481.0" spacing="20.0" VBox.vgrow="ALWAYS">
         <children>
      
                   <ProgressIndicator fx:id="loadingIndicator" managed="false" prefHeight="35" prefWidth="35" visible="false" />
      
                   <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Select Company" />
      
      
                   <TextField fx:id="companyinputField" prefHeight="40" promptText="Search Company" style="-fx-background-radius: 12;" VBox.vgrow="ALWAYS">
                       <font>
                           <Font size="14" />
                       </font>
                   </TextField>
               <ListView fx:id="companyListView" prefHeight="127.0" prefWidth="485.0" style="-fx-background-radius: 15;" />
      
                   <Button fx:id="searchBTN" onAction="#searchCompany" prefHeight="26.0" prefWidth="90.0" style="-fx-background-color: #6a00f4;                                -fx-text-fill: white;                                -fx-background-radius: 12;" text="Search" />
      
                         <ComboBox fx:id="companyComboBox" prefHeight="37.0" prefWidth="187.0" promptText="Select Company" style="-fx-background-radius: 12;" />
      
                   <Button fx:id="selectBtn" onAction="#setCompany" prefHeight="34.0" prefWidth="124.0" style="-fx-background-color: #00b4d8;                                -fx-text-fill: white;                                -fx-background-radius: 12;" text="Select Company">
                       <font>
                           <Font size="15" />
                       </font>
                   </Button>
            <Button mnemonicParsing="false" onAction="#onCreateNewCompany" prefHeight="32.0" prefWidth="121.0" style="-fx-background-color: #00b4d8; -fx-background-radius: 10;" text="Create New" textFill="WHITE">
               <font>
                  <Font size="15.0" />
               </font>
            </Button>
         </children>
         <VBox.margin>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </VBox.margin>
      </VBox>

         

    </children>
</VBox>
