<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="700.0" prefWidth="600.0" styleClass="root-pane" stylesheets="@../css/login_view.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="bikram.businessmanager.controller.LoginController">
   <children>
      <AnchorPane prefHeight="699.0" prefWidth="801.0">
         <children>
            <AnchorPane prefHeight="691.0" prefWidth="301.0" AnchorPane.bottomAnchor="0.0" AnchorPane.topAnchor="0.0">
               <children>
                  <VBox fx:id="left_vbox" alignment="CENTER" layoutX="1.0" layoutY="-51.0" prefHeight="703.0" prefWidth="351.0" AnchorPane.bottomAnchor="0.0" AnchorPane.topAnchor="0.0" />
               </children>
            </AnchorPane>
            <AnchorPane layoutX="333.0" prefHeight="703.0" prefWidth="468.0" AnchorPane.bottomAnchor="0.0" AnchorPane.topAnchor="0.0">
               <children>
                  <VBox alignment="CENTER" layoutX="17.0" layoutY="6.0" prefHeight="697.0" prefWidth="473.0" spacing="10.0" styleClass="login-card">
                     <children>
                        <Label styleClass="title-label" text="Login">
                           <font>
                              <Font size="20.0" />
                           </font>
                        </Label>
                        <Label styleClass="field-label" text="user name" />
                        <TextField fx:id="user_name_Field" alignment="CENTER" prefHeight="26.0" prefWidth="500.0" promptText="user name" styleClass="modern-field" />
                        <Label styleClass="field-label" text="password" />
                        <PasswordField fx:id="password_field" alignment="CENTER" prefHeight="41.0" prefWidth="508.0" promptText="password" styleClass="modern-field" />
                        <Button mnemonicParsing="false" onAction="#handle_login" styleClass="login-btn" text="Login">
                           <font>
                              <Font size="15.0" />
                           </font>
                           <VBox.margin>
                              <Insets top="20.0" />
                           </VBox.margin>
                        </Button>
                     </children>
                  </VBox>
               </children>
            </AnchorPane>
         </children>
      </AnchorPane>
   </children>
</VBox>
