<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="bikram.businessmanager.controller.inventory.InventoryViewController">
   <children>
      <Label text="Stock ">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
      <HBox prefHeight="60.0" prefWidth="600.0" VBox.vgrow="ALWAYS" />
      <Label fx:id="companylabelField" />
      <HBox prefHeight="37.0" prefWidth="600.0" spacing="10.0" VBox.vgrow="ALWAYS">
         <children>
            <ButtonBar prefHeight="26.0" prefWidth="43.0" />
            <TextField fx:id="serchField" prefHeight="66.0" prefWidth="443.0" promptText="🔎 Search......." HBox.hgrow="ALWAYS">
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding></TextField>
            <Button mnemonicParsing="false" onAction="#onSerchClick" prefHeight="36.0" prefWidth="74.0" text="🔎 Search" HBox.hgrow="ALWAYS" />
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </HBox>
      <TableView fx:id="inventoryTableView" prefHeight="305.0" prefWidth="600.0" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="dateColum" prefWidth="150.0" text="Date" />
          <TableColumn fx:id="productColum" prefWidth="200.0" text="Product" />
            <TableColumn fx:id="stockColum" prefWidth="100.0" text="Stock" />
            <TableColumn fx:id="actionColumn" prefWidth="100.0" text="Action" />
        </columns>
      </TableView>
   </children>
</VBox>
