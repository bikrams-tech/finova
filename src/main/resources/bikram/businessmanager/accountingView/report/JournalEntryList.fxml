<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="400.0" prefWidth="600.0" stylesheets="@../../css/table-style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="bikram.businessmanager.controller.acounting.JournalEntryListViewController">
   <HBox prefHeight="100.0" prefWidth="200.0">
      <children>
         <Button mnemonicParsing="false" onAction="#on_back" text="←" />
      </children>
   </HBox>
   <Label text="Journal Entry Table" underline="true">
      <font>
         <Font size="15.0" />
      </font>
      <padding>
         <Insets bottom="20.0" left="5.0" right="5.0" top="5.0" />
      </padding>
   </Label>
    <TableView fx:id="journalTable">
        <columns>

            <TableColumn fx:id="dateColumn" prefWidth="150.0" text="Date" />
            <TableColumn fx:id="voucherColumn" prefWidth="150.0" text="Voucher" />
            <TableColumn fx:id="typeColumn" prefWidth="100.0" text="Type" />
            <TableColumn fx:id="debitColumn" prefWidth="100.0" text="Debit" />
            <TableColumn fx:id="creditColumn" prefWidth="100.0" text="Credit" />
            <TableColumn fx:id="statusColumn" text="Status" />

        </columns>
    </TableView>
   <padding>
      <Insets bottom="15.0" left="5.0" right="5.0" top="15.0" />
   </padding>

</VBox>
