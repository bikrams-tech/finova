<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="20" style="-fx-background-color: #669999;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="bikram.businessmanager.controller.company.CompanyTableController">

    <padding>
        <Insets bottom="25" left="30" right="30" top="25" />
    </padding>

    <!-- Title Section -->
    <Label fx:id="titleLabel" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Company Management" />

    <!-- Search Section -->
    <HBox alignment="CENTER_LEFT" spacing="15">

        <TextField fx:id="searchField" promptText="Search company..." style="-fx-background-radius: 12; -fx-padding: 10 15 10 15; -fx-background-color: #e0ebeb; -fx-border-color: #dcdde1; -fx-border-radius: 12; -fx-font-size: 14px;" HBox.hgrow="ALWAYS" />

        <Button fx:id="searchBtn" onAction="#searchByBtn" style="                     -fx-background-color: #4a69bd;                     -fx-text-fill: white;                     -fx-background-radius: 12;                     -fx-padding: 10 20 10 20;                     -fx-font-size: 14px;                 " text="Search" />
    </HBox>

    <!-- Table Section -->
    <TableView fx:id="companyTableView" style="-fx-background-radius: 15; -fx-border-radius: 15; -fx-background-color: #b3cccc;" VBox.vgrow="ALWAYS">

        <columns>

            <TableColumn fx:id="idColum" prefWidth="70" text="ID" />
            <TableColumn fx:id="nameColum" text="Company Name" />
            <TableColumn fx:id="panNumbercolum" text="PAN Number" />
            <TableColumn fx:id="vatNumberColum" text="VAT Number" />
            <TableColumn fx:id="registrationNumberColum" text="Registration" />
            <TableColumn fx:id="addressColum" text="Address" />
            <TableColumn fx:id="phoneColum" text="Phone" />
            <TableColumn fx:id="emailColum" text="Email" />
            <TableColumn fx:id="fiscalyearColum" text="Fiscal Year" />
            <TableColumn fx:id="isActive" text="Active" />
            <TableColumn fx:id="branchIdColum" text="Branch ID" />
            <TableColumn fx:id="createdAtcolum" text="Created At" />

        </columns>
    </TableView>

</VBox>
