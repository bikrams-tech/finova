<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fx:id="root" fitToWidth="true"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="bikram.businessmanager.controller.company.CompanyRegisterFormController">

    <content>
        <VBox alignment="TOP_CENTER" spacing="20" style="-fx-background-color: #669999;">
            <padding>
                <Insets bottom="30" left="30" right="30" top="30" />
            </padding>

            <GridPane hgap="20" maxWidth="900" vgap="15">

                <columnConstraints>
                    <ColumnConstraints percentWidth="35" />
                    <ColumnConstraints percentWidth="65" />
                </columnConstraints>

                <rowConstraints>
                    <RowConstraints minHeight="40" prefHeight="40" />
                    <RowConstraints minHeight="40" prefHeight="40" />
                    <RowConstraints minHeight="40" prefHeight="40" />
                    <RowConstraints minHeight="40" prefHeight="40" />
                    <RowConstraints minHeight="40" prefHeight="40" />
                    <RowConstraints minHeight="40" prefHeight="40" />
                    <RowConstraints minHeight="40" prefHeight="40" />
                    <RowConstraints minHeight="40" prefHeight="40" />
                    <RowConstraints minHeight="40" prefHeight="40" />
                    <RowConstraints minHeight="40" prefHeight="40" />
                    <RowConstraints minHeight="40" prefHeight="40" />
                    <RowConstraints minHeight="40" prefHeight="40" />
                    <RowConstraints minHeight="40" prefHeight="40" />
                </rowConstraints>

                <children>

                    <!-- Company Name -->
                    <Label text="Company Name:" GridPane.rowIndex="0" />
                    <TextField fx:id="companyNameField" promptText="Enter company name"
                               style="-fx-background-color: #c2d6d6;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                    <!-- PAN -->
                    <Label text="PAN Number:" GridPane.rowIndex="1" />
                    <TextField fx:id="panField" promptText="Enter PAN number"
                               style="-fx-background-color: #c2d6d6;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                    <!-- VAT -->
                    <Label text="VAT Number:" GridPane.rowIndex="2" />
                    <TextField fx:id="vatField" promptText="Enter VAT number"
                               style="-fx-background-color: #c2d6d6;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                    <!-- Registration -->
                    <Label text="Registration No:" GridPane.rowIndex="3" />
                    <TextField fx:id="registrationField" promptText="Enter registration number"
                               style="-fx-background-color: #c2d6d6;" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                    <!-- Company Type -->
                    <Label text="Company Type:" GridPane.rowIndex="4" />
                    <ComboBox fx:id="companyTypeCombo" promptText="Select company type"
                              style="-fx-background-color: #c2d6d6;" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                    <!-- Owner Name -->
                    <Label text="Owner Name:" GridPane.rowIndex="5" />
                    <TextField fx:id="ownerField" promptText="Enter owner name"
                               style="-fx-background-color: #c2d6d6;" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                    <!-- Industry Type -->
                    <Label text="Industry Type:" GridPane.rowIndex="6" />
                    <ComboBox fx:id="industryField" promptText="Select industry type"
                               style="-fx-background-color: #c2d6d6;" GridPane.columnIndex="1" GridPane.rowIndex="6" />

                    <!-- Address -->
                    <Label text="Address:" GridPane.rowIndex="7" />
                    <TextField fx:id="addressField" promptText="Enter address"
                               style="-fx-background-color: #c2d6d6;" GridPane.columnIndex="1" GridPane.rowIndex="7" />

                    <!-- Phone -->
                    <Label text="Phone:" GridPane.rowIndex="8" />
                    <TextField fx:id="phoneField" promptText="Enter phone number"
                               style="-fx-background-color: #c2d6d6;" GridPane.columnIndex="1" GridPane.rowIndex="8" />

                    <!-- Email -->
                    <Label text="Email:" GridPane.rowIndex="9" />
                    <TextField fx:id="emailField" promptText="Enter email"
                               style="-fx-background-color: #c2d6d6;" GridPane.columnIndex="1" GridPane.rowIndex="9" />

                    <!-- Fiscal Year Start -->
                    <Label text="Fiscal Year Start:" GridPane.rowIndex="10" />
                    <DatePicker fx:id="fiscalYearStartPicker" promptText="Select start date"
                                style="-fx-background-color: #c2d6d6;" GridPane.columnIndex="1" GridPane.rowIndex="10" />

                    <!-- Fiscal Year End -->
                    <Label text="Fiscal Year End:" GridPane.rowIndex="11" />
                    <DatePicker fx:id="fiscalYearEndPicker" promptText="Select end date"
                                style="-fx-background-color: #c2d6d6;" GridPane.columnIndex="1" GridPane.rowIndex="11" />

                    <!-- Active -->
                    <Label text="Active:" GridPane.rowIndex="12" />
                    <CheckBox fx:id="activeCheck" style="-fx-background-color: #c2d6d6;" GridPane.columnIndex="1" GridPane.rowIndex="12" />

                    <!-- Branch ID -->
                    <Label text="Branch ID:" GridPane.rowIndex="13" />
                    <TextField fx:id="branchField" promptText="Enter branch ID"
                               style="-fx-background-color: #c2d6d6;" GridPane.columnIndex="1" GridPane.rowIndex="13" />

                </children>

            </GridPane>

            <!-- Buttons -->
            <HBox alignment="CENTER" spacing="15">
                <Button fx:id="saveBtn" onAction="#saveCompany" prefWidth="120"
                        style="-fx-background-color: #b9b3cc;" text="Save" />
                <Button fx:id="clearBtn" onAction="#clearForm" prefWidth="120"
                        style="-fx-background-color: #b9b3cc;" text="Clear" />
                <Button fx:id="cancelbtn" onAction="#canceltask" prefWidth="120"
                        style="-fx-background-color: #b9b3cc;" text="Cancel" />
            </HBox>

        </VBox>
    </content>
</ScrollPane>