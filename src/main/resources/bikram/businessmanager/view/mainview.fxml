<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<BorderPane fx:id="borderPane" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="bikram.businessmanager.controller.MainViewController">

    <!-- Main Content -->
    <center>
        <StackPane fx:id="mainContainer" prefHeight="600" prefWidth="800" stylesheets="@../css/menubar.css" BorderPane.alignment="CENTER" />
    </center>
   <top>
      <HBox prefHeight="42.0" prefWidth="800.0" spacing="0" styleClass="menu-bar-container" stylesheets="@../css/menubar.css" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="back_btn" mnemonicParsing="false" onAction="#on_back" prefHeight="53.0" prefWidth="58.0" styleClass="back_btn" text="⬅" />
              <MenuBar fx:id="mainMenuBar" prefHeight="42.0" HBox.hgrow="ALWAYS">
      
                  <menus>
      
                      <!-- Company Menu -->
                      <Menu style="-fx-text-fill: white;" text="🏢 Company">
                          <items>
                              <MenuItem fx:id="addcompanyMenuItem" onAction="#goToSaveCompanyForm" text="Add New Company" />
                              <MenuItem fx:id="viewcompanyBtn" onAction="#showCompanies" text="View Companies" />
                          </items>
                      </Menu>
                  <Menu mnemonicParsing="false" text=" Dash Board">
                    <items>
                      <MenuItem fx:id="openDashBoardMenuItem" mnemonicParsing="false" onAction="#openDashboard" text="Open Dash Board" />
                    </items>
                  </Menu>
                  <Menu mnemonicParsing="false" text="📉 Inventory">
                    <items>
                      <MenuItem mnemonicParsing="false" onAction="#addProduct" text="Add Product" />
                        <MenuItem mnemonicParsing="false" onAction="#on_stock_view" text="View Stock" />
                        <MenuItem fx:id="on_view_and_manage_product" mnemonicParsing="false" onAction="#showProductTable" text="View &amp; Manage Product" />
                        <MenuItem mnemonicParsing="false" onAction="#on_view_stock_transition" text="view stock Transition  history" />
                    </items>
                  </Menu>
                  <Menu mnemonicParsing="false" text="🌘Mode">
                    <items>
                      <MenuItem mnemonicParsing="false" onAction="#on_office_mode" text="🏢Office" />
                        <MenuItem mnemonicParsing="false" onAction="#on_counter_mode" text="🧑‍Counter" />
                    </items>
                  </Menu>
                  <Menu mnemonicParsing="false" text="👤 Login">
                    <items>
                      <MenuItem mnemonicParsing="false" onAction="#on_login" text="Login" />
                        <MenuItem mnemonicParsing="false" text="Logout" />
                    </items>
                  </Menu>
                  </menus>
      
                  <cursor>
                      <Cursor fx:constant="HAND" />
                  </cursor>
              </MenuBar>
         </children>
      </HBox>
   </top>

</BorderPane>
