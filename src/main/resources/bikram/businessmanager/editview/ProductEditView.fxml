<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: #f4f6f9;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="bikram.businessmanager.controller.product.ProductEditController">

    <content>
        <VBox alignment="TOP_CENTER" spacing="25" style="-fx-background-color: #f4f6f9;">

            <padding>
                <Insets bottom="30" left="30" right="30" top="30" />
            </padding>

            <!-- Title -->
            <Label style="-fx-font-size: 26px;                           -fx-font-weight: bold;                           -fx-text-fill: #2c3e50;" text="Product Create / Edit" />

            <!-- Form Card -->
            <VBox maxWidth="900" spacing="20" style="-fx-background-color: white;                          -fx-background-radius: 20;                          -fx-padding: 30;                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 20, 0, 0, 5);">

                <GridPane hgap="20" vgap="18">

                    <columnConstraints>
                        <ColumnConstraints percentWidth="35" />
                        <ColumnConstraints percentWidth="65" />
                    </columnConstraints>

                    <!-- Product Name -->
                    <Label text="Product Name:" GridPane.rowIndex="0" />
                    <TextField fx:id="nameField" promptText="Enter product name" styleClass="modern-input" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                    <!-- Barcode -->
                    <Label text="Barcode:" GridPane.rowIndex="1" />
                    <TextField fx:id="barcodeField" promptText="Scan or enter barcode" styleClass="modern-input" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                    <!-- Category -->
                    <Label text="Category:" GridPane.rowIndex="2" />
                    <ComboBox fx:id="categoryCombo" promptText="Select category" styleClass="modern-input" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                    <!-- Unit -->
                    <Label text="Unit:" GridPane.rowIndex="3" />
                    <ComboBox fx:id="unitCombo" promptText="Select unit" styleClass="modern-input" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                    <!-- Cost Price -->
                    <Label text="Cost Price:" GridPane.rowIndex="4" />
                    <TextField fx:id="costPriceField" promptText="0.00" styleClass="modern-input" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                    <!-- Selling Price -->
                    <Label text="Selling Price:" GridPane.rowIndex="5" />
                    <TextField fx:id="sellingPriceField" promptText="0.00" styleClass="modern-input" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                    <!-- VAT Applicable -->
                    <Label text="VAT Applicable:" GridPane.rowIndex="6" />
                    <CheckBox fx:id="vatApplicableCheck" GridPane.columnIndex="1" GridPane.rowIndex="6" />

                    <!-- VAT Rate -->
                    <Label text="VAT Rate (%):" GridPane.rowIndex="7" />
                    <TextField fx:id="vatRateField" promptText="13" styleClass="modern-input" GridPane.columnIndex="1" GridPane.rowIndex="7" />

                    <!-- Stock Quantity -->
                    <Label text="Company:" GridPane.rowIndex="8" />
                    <ComboBox fx:id="companyComboBox" promptText="Select Company" styleClass="modern-input" GridPane.columnIndex="1" GridPane.rowIndex="8" />


               <rowConstraints>
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
               </rowConstraints>

                </GridPane>

                <!-- Buttons -->
                <HBox alignment="CENTER_RIGHT" spacing="15">

                    <Button fx:id="saveBtn" onAction="#saveProduct" style="-fx-background-color: #4a69bd;                                    -fx-text-fill: white;                                    -fx-background-radius: 12;                                    -fx-padding: 10 25;                                    -fx-font-size: 14px;" text="Save" />

                    <Button fx:id="clearBtn" onAction="#clearForm" style="-fx-background-color: #f1f2f6;                                    -fx-text-fill: #2c3e50;                                    -fx-background-radius: 12;                                    -fx-padding: 10 25;                                    -fx-font-size: 14px;" text="Clear" />

                    <Button fx:id="cancelBtn" onAction="#cancelTask" style="-fx-background-color: #eb2f06;                                    -fx-text-fill: white;                                    -fx-background-radius: 12;                                    -fx-padding: 10 25;                                    -fx-font-size: 14px;" text="Cancel" />

                </HBox>

            </VBox>

        </VBox>
    </content>
</ScrollPane>
